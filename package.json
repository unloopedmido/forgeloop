{
	"name": "create-forgeloop",
	"version": "0.4.0",
	"description": "A maintenance-first discord.js bot template scaffolder and CLI with generators, starter presets, and project health checks.",
	"homepage": "https://unloopedmido.github.io/forgeloop/",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/unloopedmido/forgeloop.git"
	},
	"bugs": {
		"url": "https://github.com/unloopedmido/forgeloop/issues"
	},
	"type": "module",
	"packageManager": "pnpm@10.22.0",
	"bin": {
		"create-forgeloop": "bin/create-forgeloop.js",
		"forgeloop": "bin/forgeloop.js"
	},
	"exports": {
		"./config": {
			"types": "./dist/config.d.ts",
			"import": "./dist/config.js",
			"default": "./dist/config.js"
		}
	},
	"files": [
		"bin",
		"dist",
		"README.md",
		"LICENSE"
	],
	"keywords": [
		"discord",
		"discord-bot",
		"discord-bot-template",
		"discord-bot-starter",
		"discord.js",
		"discordjs",
		"scaffolder",
		"scaffold",
		"generator",
		"nodejs-cli",
		"starter",
		"template",
		"boilerplate",
		"cli",
		"create",
		"typescript",
		"javascript",
		"slash-commands",
		"discord-slash-commands",
		"bot-framework"
	],
	"license": "MIT",
	"author": "Mohammed Haism <cored.developments@gmail.com>",
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"dev": "tsx watch src/index.ts",
		"docs:dev": "pnpm --filter website run start",
		"docs:build": "pnpm --filter website run build",
		"docs:serve": "pnpm --filter website run serve",
		"lint": "eslint src tests eslint.config.js vitest.config.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run build"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.5.2",
		"@vitest/coverage-v8": "^3.2.4",
		"eslint": "^10.2.0",
		"globals": "^17.4.0",
		"prettier": "3.8.2",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vitest": "^3.2.4"
	},
	"engines": {
		"node": ">=18"
	}
}
